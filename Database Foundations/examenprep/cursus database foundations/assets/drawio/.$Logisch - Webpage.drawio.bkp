        </mxCell>
        <mxCell id="bbcOYP7T0lFPoJjijLzp-58" value="&lt;h1&gt;Waarom is &#39;Van&#39; ook PK?&lt;/h1&gt;&lt;p&gt;De primaire sleutel dient om elke record in de tabel &#39;Huurt&#39; uniek te identificeren. De combinatie van &#39;Nummerplaat&#39; en &#39;Klantennummer&#39; is daarbij onvoldoende, omdat dezelfde persoon dezelfde wagen meerdere keren zou kunnen huren. Om elke rij uniek te identificeren, gaan we de &#39;Van&#39; datum ook mee in de sleutel nemen, dezelfde klant kan een wagen meerdere keren huren, maar de &#39;Van&#39; datum zal altijd verschillend zijn.&lt;/p&gt;&lt;p&gt;Waarom nemen we de &#39;Tot&#39; datum ook niet mee in de PK? Mochten we zowel &#39;Van&#39; als &#39;Tot&#39; meenemen in de sleutel , zou dat het &#39;minimaal&#39; criterium van een primaire sleutel overtreden.&amp;nbsp;&amp;nbsp;&lt;/p&gt;" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;spacing=5;spacingTop=-20;whiteSpace=wrap;overflow=hidden;rounded=0;dashed=1;fontFamily=Noto Sans;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DNoto%2BSans;" parent="1" vertex="1">
          <mxGeometry x="70" y="290" width="320" height="260" as="geometry" />
        </mxCell>
        <mxCell id="bbcOYP7T0lFPoJjijLzp-59" value="" style="endArrow=none;dashed=1;html=1;strokeWidth=2;rounded=0;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Noto Sans;fontSource=https%3A%2F%2Ffonts.googleapis.com%2Fcss%3Ffamily%3DNoto%2BSans;" parent="1" source="bbcOYP7T0lFPoJjijLzp-42" target="bbcOYP7T0lFPoJjijLzp-58" edge="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="560" y="470" as="sourcePoint" />
            <mxPoint x="610" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>
      </root>
